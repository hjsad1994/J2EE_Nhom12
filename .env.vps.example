FRONTEND_DOMAIN=veritashop.click
API_DOMAIN=api.veritashop.click

APP_FRONTEND_URL=https://veritashop.click
APP_CORS_ALLOWED_ORIGINS=https://veritashop.click,https://www.veritashop.click
APP_WEBSOCKET_ALLOWED_ORIGIN_PATTERNS=https://veritashop.click,https://www.veritashop.click
APP_OAUTH2_FAILURE_URL=https://veritashop.click/login?error=google_failed

VITE_API_BASE_URL=https://api.veritashop.click/api
VITE_BACKEND_URL=https://api.veritashop.click
VITE_ABSA_API_BASE_URL=/absa-api

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/nhom12?appName=<cluster-name>
APP_SEED_ENABLED=false
ABSA_API_URL=http://host.docker.internal:9000

JWT_SECRET=please_replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRATION=86400000

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://api.veritashop.click/login/oauth2/code/google

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

APP_EMAIL_PROVIDER=resend
APP_EMAIL_FROM=onboarding@resend.dev
RESEND_API_KEY=re_xxxxxxxxx
RESEND_API_URL=https://api.resend.com/emails

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_API_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_IPN_URL=https://api.veritashop.click/momo/ipn
MOMO_REDIRECT_URL=https://api.veritashop.click/momo/return
